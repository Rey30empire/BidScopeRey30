generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NETLIFY_DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  location    String?
  address     String?
  city        String?
  state       String?
  zip         String?
  projectSize String?
  trade       String?
  status      String   @default("upload")
  bidDueDate  DateTime?
  rfiDueDate  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  files    BidFile[]
  analysis Analysis?
  estimates Estimate[]
}

model BidFile {
  id             String   @id @default(cuid())
  projectId      String
  originalName   String
  fileName       String
  filePath       String
  fileType       String
  fileSize       Int
  mimeType       String?
  hash           String?
  category       String?
  relevanceScore Float?
  summary        String?
  sheetData      String?
  metadata       String?
  isRelevant     Boolean?
  isProcessed    Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Analysis {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  projectName         String?
  client              String?
  contact             String?
  email               String?
  bidDueDate          String?
  rfiDueDate          String?
  address             String?
  city                String?
  state               String?
  zipCode             String?
  trade               String?
  scopeHints          String?
  alternates          String?
  allowances          String?
  proposalReqs        String?
  insuranceReqs       String?
  scheduleConstraints String?
  addendaNotes        String?
  keySpecs            String?
  materials           String?
  relevantSheets      String?
  scopeAnalysis       String?
  weatherImpact       String?
  timeEstimate        String?
  executiveSummary    String?
  riskItems           String?
  rfiSuggestions      String?
  costEstimate        String?
  inclusions          String?
  exclusions          String?
  confidence          Float?
  status              String   @default("pending")
  error               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Settings {
  id        String   @id @default("default")
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Estimate {
  id                        String   @id @default(cuid())
  projectId                 String
  estimateType              String
  estimateNumber            String
  title                     String
  versionLabel              String   @default("V1")
  status                    String   @default("Draft")
  preparedBy                String?
  preparedByTitle           String?
  reviewedBy                String?
  reviewedByTitle           String?
  companyName               String?
  companyEmail              String?
  companyPhone              String?
  companyAddress            String?
  clientRecipientName       String?
  clientRecipientEmail      String?
  validForDays              Int      @default(30)
  currency                  String   @default("USD")
  executiveSummary          String?
  scopeOfWork               String?
  inclusions                String?
  exclusions                String?
  clarifications            String?
  qualifications            String?
  proposalNotes             String?
  keyDocuments              String?
  keyPlansAndSpecs          String?
  costItems                 String?
  pricingSummary            String?
  questionnaireTemplateId   String?
  questionnaireTrade        String?
  questionnaireState        String?
  internalAssumptions       String?
  internalInferredData      String?
  internalTechnicalBacking  String?
  internalAnalysisNotes     String?
  internalReviewComments    String?
  riskRegister              String?
  rfiRegister               String?
  weatherNotes              String?
  timeEstimateNotes         String?
  acceptanceEnabled         Boolean  @default(true)
  clientDisclaimer          String?
  internalDisclaimer        String?
  humanApprovedForClientExport Boolean @default(false)
  humanApprovedForSend      Boolean  @default(false)
  approvedForClientExportAt DateTime?
  approvedForSendAt         DateTime?
  sentCount                 Int      @default(0)
  openCount                 Int      @default(0)
  firstOpenedAt             DateTime?
  lastOpenedAt              DateTime?
  lastSentAt                DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  project                   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sends                     EstimateSend[]
  activity                  EstimateActivityEvent[]

  @@unique([projectId, estimateType])
}

model EstimateSend {
  id                      String   @id @default(cuid())
  estimateId              String
  documentVersion         String
  recipientEmail          String
  recipientName           String?
  sentByUserId            String?
  sentByName              String?
  sentByEmail             String?
  secureToken             String   @unique
  secureViewUrl           String?
  secureDownloadUrl       String?
  htmlTrackingPixelUrl    String?
  status                  String   @default("Sent")
  openCount               Int      @default(0)
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  linkExpiresAt           DateTime?
  sentAt                  DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  estimate                Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  openEvents              EstimateOpenEvent[]
  notificationEvents      EstimateNotificationEvent[]
  activity                EstimateActivityEvent[]
}

model EstimateOpenEvent {
  id                      String   @id @default(cuid())
  estimateSendId          String
  openedAt                DateTime @default(now())
  ipAddress               String?
  userAgent               String?
  referrer                String?
  eventType               String
  sourceType              String?
  isFirstOpen             Boolean  @default(false)
  openCountAtEvent        Int      @default(1)
  createdAt               DateTime @default(now())

  estimateSend            EstimateSend @relation(fields: [estimateSendId], references: [id], onDelete: Cascade)
  notificationEvents      EstimateNotificationEvent[]
}

model EstimateNotificationEvent {
  id                      String   @id @default(cuid())
  estimateSendId          String
  estimateOpenEventId     String
  notifiedAt              DateTime @default(now())
  notificationChannel     String   @default("email")
  recipientInternalEmail  String
  deliveryStatus          String
  providerMessageId       String?
  createdAt               DateTime @default(now())

  estimateSend            EstimateSend @relation(fields: [estimateSendId], references: [id], onDelete: Cascade)
  estimateOpenEvent       EstimateOpenEvent @relation(fields: [estimateOpenEventId], references: [id], onDelete: Cascade)
}

model EstimateActivityEvent {
  id                      String   @id @default(cuid())
  estimateId              String
  estimateSendId          String?
  activityType            String
  title                   String
  description             String?
  metadata                String?
  createdAt               DateTime @default(now())

  estimate                Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateSend            EstimateSend? @relation(fields: [estimateSendId], references: [id], onDelete: SetNull)
}
