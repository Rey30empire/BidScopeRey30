generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  client      String?
  location    String?
  address     String?
  city        String?
  state       String?
  zip         String?
  projectSize String?
  trade       String?
  status      String   @default("upload") // upload | processing | complete | error
  bidDueDate  DateTime?
  rfiDueDate  DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  files    BidFile[]
  analysis Analysis?
  estimates Estimate[]
}

model BidFile {
  id           String   @id @default(cuid())
  projectId    String
  originalName String
  fileName     String
  filePath     String
  fileType     String   // pdf, docx, xlsx, csv, txt, image, zip, other
  fileSize     Int
  mimeType     String?
  hash         String?
  category     String?  // drawings, addenda, specifications, civil, structural, architectural, mep, site, geotech, fire_protection, bid_forms, rfi, irrelevant
  relevanceScore Float?  // 0-1 relevance score
  summary      String?  // AI-generated summary
  sheetData    String?  // JSON: detected sheets/titles
  metadata     String?  // JSON: extracted metadata
  isRelevant   Boolean?
  isProcessed  Boolean  @default(false)
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Analysis {
  id              String   @id @default(cuid())
  projectId       String   @unique
  projectName     String?
  client          String?
  contact         String?
  email           String?
  bidDueDate      String?
  rfiDueDate      String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  trade           String?
  scopeHints      String?  // JSON
  alternates      String?  // JSON
  allowances      String?  // JSON
  proposalReqs    String?  // JSON
  insuranceReqs   String?  // JSON
  scheduleConstraints String? // JSON
  addendaNotes    String?  // JSON
  keySpecs        String?  // JSON
  materials       String?  // JSON
  relevantSheets  String?  // JSON
  scopeAnalysis   String?  // JSON: { probableScope, priorityDocs, keySheets, keySpecs, risks, exclusions, rfis }
  weatherImpact   String?  // JSON
  timeEstimate    String?  // JSON
  executiveSummary String? // JSON
  riskItems       String?  // JSON
  rfiSuggestions  String?  // JSON
  costEstimate    String?  // JSON
  inclusions      String?  // JSON
  exclusions      String?  // JSON
  confidence      Float?   // 0-1
  status          String   @default("pending") // pending | processing | complete | error
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Settings {
  id    String @id @default("default")
  key   String @unique
  value String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Estimate {
  id                      String   @id @default(cuid())
  projectId               String
  estimateType            String   // trade | global
  estimateNumber          String
  title                   String
  versionLabel            String   @default("V1")
  status                  String   @default("Draft")
  preparedBy              String?
  preparedByTitle         String?
  reviewedBy              String?
  reviewedByTitle         String?
  companyName             String?
  companyEmail            String?
  companyPhone            String?
  companyAddress          String?
  clientRecipientName     String?
  clientRecipientEmail    String?
  validForDays            Int      @default(30)
  currency                String   @default("USD")
  executiveSummary        String?
  scopeOfWork             String?
  inclusions              String?  // JSON
  exclusions              String?  // JSON
  clarifications          String?  // JSON
  qualifications          String?  // JSON
  proposalNotes           String?  // JSON
  keyDocuments            String?  // JSON
  keyPlansAndSpecs        String?  // JSON
  costItems               String?  // JSON
  pricingSummary          String?  // JSON
  questionnaireTemplateId String?
  questionnaireTrade      String?
  questionnaireState      String?  // JSON
  internalAssumptions     String?  // JSON
  internalInferredData    String?  // JSON
  internalTechnicalBacking String? // JSON
  internalAnalysisNotes   String?  // JSON
  internalReviewComments  String?  // JSON
  riskRegister            String?  // JSON
  rfiRegister             String?  // JSON
  weatherNotes            String?  // JSON
  timeEstimateNotes       String?  // JSON
  acceptanceEnabled       Boolean  @default(true)
  clientDisclaimer        String?
  internalDisclaimer      String?
  humanApprovedForClientExport Boolean @default(false)
  humanApprovedForSend    Boolean  @default(false)
  approvedForClientExportAt DateTime?
  approvedForSendAt       DateTime?
  sentCount               Int      @default(0)
  openCount               Int      @default(0)
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  lastSentAt              DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  project                 Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sends                   EstimateSend[]
  activity                EstimateActivityEvent[]

  @@unique([projectId, estimateType])
}

model EstimateSend {
  id                      String   @id @default(cuid())
  estimateId              String
  documentVersion         String   // client_trade | client_global | internal_review
  recipientEmail          String
  recipientName           String?
  sentByUserId            String?
  sentByName              String?
  sentByEmail             String?
  secureToken             String   @unique
  secureViewUrl           String?
  secureDownloadUrl       String?
  htmlTrackingPixelUrl    String?
  status                  String   @default("Sent")
  openCount               Int      @default(0)
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  linkExpiresAt           DateTime?
  sentAt                  DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  estimate                Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  openEvents              EstimateOpenEvent[]
  notificationEvents      EstimateNotificationEvent[]
  activity                EstimateActivityEvent[]
}

model EstimateOpenEvent {
  id                      String   @id @default(cuid())
  estimateSendId          String
  openedAt                DateTime @default(now())
  ipAddress               String?
  userAgent               String?
  referrer                String?
  eventType               String   // portal_open | pixel_open | download_open | re_open
  sourceType              String?  // portal | pixel | download
  isFirstOpen             Boolean  @default(false)
  openCountAtEvent        Int      @default(1)
  createdAt               DateTime @default(now())

  estimateSend            EstimateSend @relation(fields: [estimateSendId], references: [id], onDelete: Cascade)
  notificationEvents      EstimateNotificationEvent[]
}

model EstimateNotificationEvent {
  id                      String   @id @default(cuid())
  estimateSendId          String
  estimateOpenEventId     String
  notifiedAt              DateTime @default(now())
  notificationChannel     String   @default("email")
  recipientInternalEmail  String
  deliveryStatus          String
  providerMessageId       String?
  createdAt               DateTime @default(now())

  estimateSend            EstimateSend @relation(fields: [estimateSendId], references: [id], onDelete: Cascade)
  estimateOpenEvent       EstimateOpenEvent @relation(fields: [estimateOpenEventId], references: [id], onDelete: Cascade)
}

model EstimateActivityEvent {
  id                      String   @id @default(cuid())
  estimateId              String
  estimateSendId          String?
  activityType            String   // status_changed | sent | portal_open | pixel_open | download_open | re_open | notification_sent
  title                   String
  description             String?
  metadata                String?  // JSON
  createdAt               DateTime @default(now())

  estimate                Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  estimateSend            EstimateSend? @relation(fields: [estimateSendId], references: [id], onDelete: SetNull)
}
